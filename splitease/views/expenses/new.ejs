<% const title = 'Add Expense'; const page = 'expenses'; %>
<%- include('../partials/header') %>

<div class="form-page">
  <div class="card form-card">
    <div class="card-head">
      <h2><i class="fa-solid fa-plus-circle"></i> Add New Expense</h2>
    </div>
    <form action="/expenses" method="POST" class="main-form" id="expenseForm">

      <div class="form-row">
        <div class="form-group" style="flex:2">
          <label>Description <span class="req">*</span></label>
          <input type="text" name="description" placeholder="e.g. Dinner at Spice Garden" required/>
        </div>
        <div class="form-group">
          <label>Amount (₹) <span class="req">*</span></label>
          <input type="number" name="amount" id="amount" placeholder="0.00" step="0.01" min="0.01" required/>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Paid By <span class="req">*</span></label>
          <select name="paid_by" id="paid_by">
            <option value="<%= user.id %>"><%= user.name %> (You)</option>
            <% friends.forEach(f => { %>
              <option value="<%= f.id %>"><%= f.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <% categories.forEach(c => { %>
              <option value="<%= c %>"><%= c %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Date</label>
          <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>"/>
        </div>
      </div>

      <div class="form-group">
        <label>Group (optional)</label>
        <select name="group_id" id="group_id">
          <option value="">No group</option>
          <% groups.forEach(g => { %>
            <option value="<%= g.id %>" <%= preGroup == g.id ? 'selected' : '' %>><%= g.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Split With</label>
        <% if (friends.length === 0) { %>
          <p class="hint-text">Add friends first to split expenses. <a href="/friends">Add friends →</a></p>
        <% } else { %>
          <div class="checkbox-grid" id="split-members">
            <% friends.forEach(f => { %>
              <label class="check-label">
                <input type="checkbox" name="members" value="<%= f.id %>" onchange="updateCustomSplit()"/>
                <div class="user-ava xs"><%= f.name[0].toUpperCase() %></div>
                <%= f.name %>
              </label>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="form-group">
        <label>Split Type</label>
        <div class="split-type-row">
          <label class="radio-pill">
            <input type="radio" name="split_type" value="equal" checked onchange="setSplitType('equal')"/>
            <span><i class="fa-solid fa-equals"></i> Equal Split</span>
          </label>
          <label class="radio-pill">
            <input type="radio" name="split_type" value="custom" onchange="setSplitType('custom')"/>
            <span><i class="fa-solid fa-sliders"></i> Custom Split</span>
          </label>
        </div>
      </div>

      <div id="custom-split-area" style="display:none">
        <div class="form-group">
          <label>Custom Shares (must add up to total)</label>
          <div id="custom-inputs" class="custom-grid"></div>
          <p class="hint-text" id="custom-total-hint"></p>
        </div>
      </div>

      <div class="form-group">
        <label>Notes (optional)</label>
        <input type="text" name="notes" placeholder="Any extra details…"/>
      </div>

      <div class="form-actions">
        <a href="/expenses" class="btn-secondary">Cancel</a>
        <button type="submit" class="btn-primary"><i class="fa-solid fa-plus"></i> Add Expense</button>
      </div>
    </form>
  </div>
</div>

<script>
const currentUser = { id: '<%= user.id %>', name: '<%= user.name %>' };
const allFriends  = <%- JSON.stringify(friends) %>;
let splitMode = 'equal';

function setSplitType(type) {
  splitMode = type;
  document.getElementById('custom-split-area').style.display = type === 'custom' ? 'block' : 'none';
  if (type === 'custom') updateCustomSplit();
}

function updateCustomSplit() {
  if (splitMode !== 'custom') return;
  const checked = [...document.querySelectorAll('input[name="members"]:checked')].map(c => parseInt(c.value));
  const paidBy  = parseInt(document.getElementById('paid_by').value);
  const participants = [...new Set([...checked, paidBy])];

  const amount = parseFloat(document.getElementById('amount').value) || 0;
  const equal  = participants.length ? +(amount / participants.length).toFixed(2) : 0;

  const container = document.getElementById('custom-inputs');
  container.innerHTML = participants.map((pid, i) => {
    const name = pid == currentUser.id ? currentUser.name + ' (You)' : (allFriends.find(f => f.id == pid)?.name || 'Unknown');
    return `
      <div class="custom-split-item">
        <div class="user-ava xs">${name[0].toUpperCase()}</div>
        <label>${name}</label>
        <input type="number" name="custom_shares" value="${equal}" step="0.01" min="0" oninput="updateTotalHint()"/>
      </div>
    `;
  }).join('');
  updateTotalHint();
}

function updateTotalHint() {
  const amount = parseFloat(document.getElementById('amount').value) || 0;
  const shares = [...document.querySelectorAll('input[name="custom_shares"]')].map(i => parseFloat(i.value) || 0);
  const total  = shares.reduce((a, b) => a + b, 0);
  const hint   = document.getElementById('custom-total-hint');
  hint.textContent = `Total: ₹${total.toFixed(2)} / ₹${amount.toFixed(2)}`;
  hint.style.color = Math.abs(total - amount) < 0.01 ? '#22c55e' : '#ef4444';
}

document.getElementById('amount').addEventListener('input', () => {
  if (splitMode === 'custom') updateCustomSplit();
});
</script>

<%- include('../partials/footer') %>
