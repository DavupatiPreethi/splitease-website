<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= code %> – SplitEase</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Sora:wght@800&display=swap" rel="stylesheet"/>
</head>
<body class="auth-body">
  <div style="text-align:center; padding:60px 20px;">
    <div style="font-size:5rem; font-family:'Sora',sans-serif; color:#6366f1;"><%= code %></div>
    <h2 style="margin:16px 0 8px; font-size:1.4rem;"><%= message %></h2>
    <p style="color:#9ca3af; margin-bottom:28px;">Oops, something went wrong.</p>
    <a href="/dashboard" style="background:#6366f1;color:#fff;padding:10px 24px;border-radius:10px;text-decoration:none;font-weight:600;">Go Home</a>
  </div>
</body>
</html>
