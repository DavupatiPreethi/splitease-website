<% const title = 'Activity'; const page = 'activity'; %>
<%- include('partials/header') %>

<div class="card">
  <div class="card-head">
    <h2>Recent Activity</h2>
    <span class="badge"><%= logs.length %></span>
  </div>

  <% if (logs.length === 0) { %>
    <div class="empty-state">
      <i class="fa-solid fa-clock-rotate-left"></i>
      <p>No activity yet.</p>
    </div>
  <% } else { %>
    <div class="activity-list">
      <% logs.forEach(log => { %>
        <div class="activity-item">
          <div class="activity-icon <%= getTypeClass(log.type) %>">
            <i class="<%= getTypeIcon(log.type) %>"></i>
          </div>
          <div class="activity-body">
            <p class="activity-msg"><%= log.message %></p>
            <span class="activity-time"><%= new Date(log.created_at).toLocaleString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%
function getTypeIcon(type) {
  const map = { register:'fa-solid fa-user-plus', expense:'fa-solid fa-receipt', friend:'fa-solid fa-user-group', group:'fa-solid fa-people-group', settle:'fa-solid fa-handshake', delete:'fa-solid fa-trash' };
  return map[type] || 'fa-solid fa-circle-info';
}
function getTypeClass(type) {
  const map = { register:'act-purple', expense:'act-blue', friend:'act-green', group:'act-orange', settle:'act-teal', delete:'act-red' };
  return map[type] || 'act-blue';
}
%>

<%- include('partials/footer') %>
